# Backend environment configuration (example)
# Copy this file to .env in the project root (or wherever your process runs from).
# The app uses pydantic-settings and loads .env from the current working directory by default.

# Database (SQLite is zero-setup for development)
DATABASE_URL=sqlite:///./hrms.db

# Security / JWT
JWT_SECRET_KEY=super-secret-hrms-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Switch to PostgreSQL (later) ---
# 1. Start with: docker-compose up -d
# 2. Set the URL below
# 3. pip install psycopg2-binary
# 4. Restart the server
# DATABASE_URL=postgresql://hrms_user:hrms_pass@localhost:5432/hrms_db
